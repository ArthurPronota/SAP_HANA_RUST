# Параметры соединения с Kafka (bootstrap servers)
KAFKA_BROKERS=localhost:9092

# Топик, в который отправляются сообщения
KAFKA_TOPIC=log_users

# Таймаут операции отправки сообщения (секунды)
KAFKA_TIMEOUT=5

# Таймаут установки соединения с брокером (секунды)
KAFKA_CONNECT_TIMEOUT=10

# SAP HANA ODBC (без DSN): задайте host, порт, UID и PWD
HANA_ODBC_CONNECTION=Driver={HDBODBC};ServerNode=hana-host.example.com:30015;UID=MYUSER;PWD=MYPASSWORD;
