# Параметры соединения с Kafka (bootstrap servers)
KAFKA_BROKERS=localhost:9092

# Топик, из которого читаются сообщения
KAFKA_TOPIC=log-entries

# Таймаут операции отправки сообщения (секунды)
KAFKA_TIMEOUT=5

# Таймаут установки соединения с брокером (секунды)
KAFKA_CONNECT_TIMEOUT=10

# Корень warehouse Apache Iceberg (локальный путь к каталогу данных и метаданных)
ICEBERG_WAREHOUSE=C:/Data/iceberg-warehouse
